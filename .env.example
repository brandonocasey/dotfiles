# Copy to .env (docker compose reads it automatically). This pins the container
# user to YOUR host user so files written into the bind mount are owned by you.
#
#   cp .env.example .env
#   printf 'USER=%s\nUID=%s\nGID=%s\n' "$(whoami)" "$(id -u)" "$(id -g)" >> .env
#
# Needed because fish (and some shells) don't export $UID/$GID, so without this
# `docker compose` falls back to UID/GID 1000 and bind-mount ownership mismatches
# on Linux hosts. (On macOS, Docker Desktop maps ownership for you regardless.)

USER=bcasey
UID=1000
GID=1000

# Single host folder that holds ALL persistent state (projects, Claude/Codex/
# opencode auth + sessions, nvim state, shell history). Back up / move just this.
STATE_DIR=./state

# Optional SSH/mosh access into the container (see README).
ENABLE_SSHD=0
# SSH_PUBKEY=ssh-ed25519 AAAA... you@host
# SSH_PORT=2222
