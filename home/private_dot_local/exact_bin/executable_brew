#!/usr/bin/env bash
# ~/.local/bin/brew — resolves before the real brew on PATH (see fish 1-env.fish).
#
#   Linux : wrap the Homebrew at /home/linuxbrew/.linuxbrew. If we're root, drop
#           to the owning `linuxbrew` user (Homebrew refuses to run as root);
#           otherwise run it directly.
#   macOS : the Linuxbrew path doesn't exist, so pass straight through to the
#           native brew by ABSOLUTE path — calling `brew` would re-enter this
#           wrapper and loop forever.
#   Neither: fail loudly — brew isn't actually installed.
set -euo pipefail

linux_brew=/home/linuxbrew/.linuxbrew/bin/brew

if [[ -x "$linux_brew" ]]; then
    eval "$("$linux_brew" shellenv)"
    if [[ "$(id -u)" -eq 0 ]]; then
        cd /home/linuxbrew
        exec su linuxbrew -s "$linux_brew" -- "$@"
    fi
    exec "$linux_brew" "$@"
fi

for mac_brew in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "$mac_brew" ]]; then
        exec "$mac_brew" "$@"
    fi
done

echo "brew: not installed — no Homebrew found at /home/linuxbrew, /opt/homebrew, or /usr/local" >&2
exit 127
