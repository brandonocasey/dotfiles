#!/usr/bin/env bash
set -euo pipefail

# Patches Homebrew's tmux with an embedded Info.plist so macOS allows
# local network access from tmux sessions (fixes git push, ssh, etc.).
# Re-run after every `brew upgrade tmux`.

TMUX_BIN="$(brew --prefix)/bin/tmux"
TMUX_CELLAR_BIN="$(brew --cellar tmux)/$(brew list --versions tmux | awk '{print $2}')/bin/tmux"
TMUX_VERSION="$(tmux -V | awk '{print $2}')"
TARBALL_URL="https://github.com/tmux/tmux/releases/download/${TMUX_VERSION}/tmux-${TMUX_VERSION}.tar.gz"
WORK_DIR="$(mktemp -d)"

cleanup() { rm -rf "$WORK_DIR"; }
trap cleanup EXIT

echo "==> Checking current tmux..."
if otool -l "$TMUX_BIN" 2>/dev/null | grep -q __info_plist; then
  echo "tmux already has an embedded Info.plist. Nothing to do."
  echo "Run with --force to rebuild anyway."
  [[ "${1:-}" == "--force" ]] || exit 0
fi

echo "==> Downloading tmux ${TMUX_VERSION} source..."
curl -fL "$TARBALL_URL" | tar xz -C "$WORK_DIR"

SRC_DIR="$WORK_DIR/tmux-${TMUX_VERSION}"

echo "==> Creating Info.plist..."
cat > "$SRC_DIR/Info.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.github.tmux</string>
    <key>CFBundleName</key>
    <string>tmux</string>
    <key>CFBundleVersion</key>
    <string>${TMUX_VERSION}</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>tmux needs access to the local network to manage terminal sessions.</string>
</dict>
</plist>
PLIST

echo "==> Configuring (matching Homebrew formula)..."
cd "$SRC_DIR"
./configure \
  --enable-sixel \
  --enable-utf8proc \
  --sysconfdir="$(brew --prefix)/etc" \
  --prefix="$(brew --cellar tmux)/${TMUX_VERSION}" \
  LDFLAGS="-Wl,-sectcreate,__TEXT,__info_plist,Info.plist" \
  > /dev/null 2>&1

echo "==> Building..."
make -j"$(sysctl -n hw.ncpu)" > /dev/null 2>&1

echo "==> Signing..."
codesign -s - -f ./tmux 2>/dev/null

echo "==> Testing server..."
SOCKET="$WORK_DIR/test-socket"
if ./tmux -S "$SOCKET" new-session -d -s _patch_test 2>/dev/null; then
  ./tmux -S "$SOCKET" kill-server 2>/dev/null
  echo "    Server test passed."
else
  echo "ERROR: Built tmux server failed to start. Aborting." >&2
  exit 1
fi

echo "==> Installing..."
chmod u+w "$TMUX_CELLAR_BIN"
cp ./tmux "$TMUX_CELLAR_BIN"
chmod u-w "$TMUX_CELLAR_BIN"

echo "==> Pinning tmux..."
brew pin tmux 2>/dev/null

echo "==> Verifying..."
if otool -l "$TMUX_BIN" | grep -q __info_plist; then
  echo "    Info.plist embedded."
else
  echo "ERROR: Info.plist not found in installed binary." >&2
  exit 1
fi

IDENT="$(codesign -dvvv "$TMUX_BIN" 2>&1 | grep 'Identifier=' | head -1)"
echo "    ${IDENT}"

echo ""
echo "Done. Restart your tmux server:"
echo "  tmux kill-server && tmux new"
