
README.md
.chezmoiscripts/.script-env.sh
# Natively installed on Linux into ~/.local/bin (see any-linux pre-install);
# ignore so the exact_bin directory doesn't delete them on `chezmoi apply`.
.local/bin/claude
.local/bin/codex*
.local/bin/opencode
.local/bin/tokensave

# ignore these files if not on Mac
{{- if ne .chezmoi.os "darwin" }}
.chezmoiscripts/darwin/**
.config/karabiner
.config/hammerspoon
.config/iterm2
.config/linearmouse
.config/brewfile/Brewfile-mac
.vscode-oss/
Library/
# Mac-only shims — these symlinks target /Users/bcasey paths that only exist on
# macOS. Ignore off-Mac so exact_bin leaves them alone (and doesn't recreate the
# dead links); the symlink_* source files stay for the Mac.
.local/bin/agent
.local/bin/headroom
.local/bin/python3.14
{{- end }}

# ignore these files if not on windows
{{- if ne .chezmoi.os "windows" }}
.chezmoiscripts/windows/**
# ignore these files only on windows
{{- else }}
.config/*
!.config/wezterm/**
.envrc
.telnetrc
.tool-versions
.local
{{- end }}

# ignore these files if not on linux or on windows subsystem for linux
{{- if (or (ne .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft")) }}
.chezmoiscripts/linux/**
{{- end }}

# ignore these files if not on Linux or Mac
{{- if (and (ne .chezmoi.os "linux") (ne .chezmoi.os "darwin")) }}
# WSL-specific code
.chezmoiscripts/any-linux/**
{{- end }}
